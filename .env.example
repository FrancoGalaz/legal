# ========================================
# Legal Agent CL — Environment Variables
# ========================================
# Copy this to services/api/.env and fill in your values

APP_NAME=legal-agent-api
APP_VERSION=0.1.0
DEBUG=false

# Frontend URL for CORS (comma-separated, JSON array)
# Dev: ["http://localhost:3000"]
# Prod: ["http://localhost:3000","https://francogalaz.github.io"]
CORS_ORIGINS=["http://localhost:3000"]

# Database — SQLite for dev, PostgreSQL for production
# Dev: sqlite+aiosqlite:///./legal_agent.db
# Prod: postgresql+asyncpg://user:pass@host:5432/legal_agent
DATABASE_URL=sqlite+aiosqlite:///./legal_agent.db

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication — generate a secure random key for production!
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-use-a-real-secret
JWT_EXPIRATION_DAYS=30

# LLM — OpenRouter (recommended) or OpenAI
# Set OPENROUTER_API_KEY or OPENAI_API_KEY
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash

# Flow.cl payment gateway — https://www.flow.cl/
# Required for payment processing in production
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://www.flow.cl/api
FLOW_RETURN_URL=http://localhost:3000/app/payment/return
FLOW_CONFIRMATION_URL=http://localhost:8000/pricing/flow-webhook
