# Legal Agent CL API — Environment Variables
# Copy this file to .env and fill in your values.

# ─── App ────────────────────────────────────────────────
APP_NAME=legal-agent-api
APP_VERSION=0.1.0
DEBUG=true

# ─── Database ───────────────────────────────────────────
# PostgreSQL with asyncpg for production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_agent
# SQLite for local dev/tests (change to postgresql for prod)
# DATABASE_URL=sqlite+aiosqlite:///./legal_agent.db
REDIS_URL=redis://localhost:6379/0

# ─── CORS ───────────────────────────────────────────────
# Frontend URL(s) allowed to connect to this API
CORS_ORIGINS=["http://localhost:3000","https://francogalaz.github.io"]

# ─── JWT Auth ──────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_DAYS=30

# ─── LLM Provider ──────────────────────────────────────
# Either OpenAI or OpenRouter (preferred for Chilean legal prompts)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash

# ─── Flow.cl Payment Gateway ─────────────────────────────
# Create account at https://www.flow.cl/ and get API credentials
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://www.flow.cl/api
# Production URLs (change these for your production domain)
FLOW_RETURN_URL=http://localhost:3000/app/payment/return
FLOW_CONFIRMATION_URL=http://localhost:8000/pricing/flow-webhook
